EMAIL_ACCOUNT = "your-gmail-address@gmail.com"
APP_PASSWORD = "your-16-char-gmail-app-password"

# Supabase project -> Project Settings -> Database -> Connection string -> URI
# Use the "Transaction" connection pooler (port 6543), not the direct connection -
# Streamlit reruns open/close many short-lived connections, which the pooler is built for.
SUPABASE_DB_URL = "postgresql://postgres.xxxx:[password]@xxxx.pooler.supabase.com:6543/postgres"
